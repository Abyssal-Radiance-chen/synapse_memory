# ==============================================================================
# LLM 配置
# ==============================================================================
LLM_PROVIDER=qwen
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://your-llm-endpoint/v1
LLM_VERIFY_SSL=true

# 默认模型（通用任务）
LLM_MODEL=your-model-name

# 不同场景使用的模型（可独立配置，默认与 LLM_MODEL 相同）
LLM_MODEL_SUMMARY=your-model-name
LLM_MODEL_ENTITY=your-model-name
LLM_MODEL_TOPIC=your-model-name
LLM_MODEL_AGENT=your-model-name
LLM_MODEL_QUERY=your-model-name

# ==============================================================================
# Embedding 配置
# ==============================================================================
EMBEDDING_BASE_URL=https://your-embedding-endpoint/v1/embeddings
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_NAME=your-embedding-model
EMBEDDING_DIM=1024

# ==============================================================================
# Rerank 配置
# ==============================================================================
RERANK_URL=https://your-rerank-endpoint/v1/rerank
RERANK_MODEL=your-rerank-model
RERANK_API_KEY=your-rerank-api-key

# ==============================================================================
# PostgreSQL 配置
# ==============================================================================
PG_USER=postgres #PostgreSQL: https://supabase.com/
PG_PASSWORD=your-pg-password
PG_HOST=localhost
PG_PORT=5432
PG_DBNAME=synapse_memory

# ==============================================================================
# Milvus 配置 (Zilliz Cloud Serverless 或本地部署)
# ==============================================================================
MILVUS_URI=https://your-milvus-endpoint #Mlivus cloud: https://cloud.zilliz.com/
MILVUS_TOKEN=your-milvus-token
MILVUS_COLLECTION_NAME=event_vectors

# ==============================================================================
# Neo4j 配置 (知识图谱)
# ==============================================================================
NEO4J_URI=neo4j+ssc://your-neo4j-host #neo4j cloud: https://console-preview.neo4j.io/
NEO4J_USER=your-neo4j-user
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j

# ==============================================================================
# Elasticsearch 配置 (可选备用)
# ==============================================================================
ES_URL=https://your-es-endpoint
ES_USER=your-es-user
ES_PASSWORD=your-es-password
ES_API_KEY=your-es-api-key
ES_CHUNKS_INDEX=chunks_index
ES_SUMMARIES_INDEX=summaries_index

# ==============================================================================
# 天气 API 配置
# ==============================================================================
WEATHER_API_KEY=your-weather-api-key #知心天气：https://www.seniverse.com/api
WEATHER_CITY=苏州

# ==============================================================================
# 服务配置
# ==============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ==============================================================================
# 超参数
# ==============================================================================
MAX_CONTEXT_EVENTS=5
MAX_ASYNC_QUERIES=5
MAX_RETRIEVAL_ROUNDS=2
MAX_FULL_SCENES=1
MAX_MEMORY_TOKENS=8192
